{
  "name": "unity-for-cursor",
  "displayName": "Unity for Cursor",
  "description": "Discover the local Unity Editor process and attach the JetBrains \"C# by ReSharper\" mono debugger to it for breakpoint debugging.",
  "version": "0.2.0",
  "publisher": "local",
  "author": "Airuxul",
  "private": true,
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Airuxul/unity-for-cursor.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "extensionDependencies": [
    "JetBrains.resharper-code"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorUnityAttach.attachToEditor",
        "title": "Attach to Unity Editor",
        "category": "Unity for Cursor"
      },
      {
        "command": "unityForCursor.showEditorLog",
        "title": "Show Unity Editor Log",
        "category": "Unity for Cursor"
      },
      {
        "command": "unityForCursor.findSceneUsages",
        "title": "Find Usages in Scenes/Prefabs",
        "category": "Unity for Cursor"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "unityForCursor.findSceneUsages",
          "when": "resourceLangId == csharp",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "unityForCursor.findSceneUsages",
          "when": "resourceExtname == .cs",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Unity for Cursor",
      "properties": {
        "unityForCursor.ignoreBreakpointsGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/Library/**",
            "**/Packages/**"
          ],
          "description": "匹配到这些 glob 的脚本文件中，新增的断点会被自动禁用（手动重新启用后不会被再次禁用）。仅支持 *、**、? 和 {a,b} 大括号展开，不支持 [abc] 字符类或 !取反。"
        },
        "unityForCursor.enableCompileStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "在状态栏显示 Unity 正在编译/Domain Reload 的指示。"
        },
        "unityForCursor.enableLifecycleHover": {
          "type": "boolean",
          "default": true,
          "description": "悬浮在 Unity 生命周期方法（Awake/Update 等）上时显示说明。"
        },
        "unityForCursor.enableSceneUsagesHover": {
          "type": "boolean",
          "default": true,
          "description": "悬浮在脚本的类名（声明行）上时，显示引用该脚本的场景/预制体列表并可点击跳转。"
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "unityForCursorLog",
          "title": "Unity Editor Log",
          "icon": "resources/log-icon.svg"
        }
      ]
    },
    "views": {
      "unityForCursorLog": [
        {
          "id": "unityForCursor.editorLogView",
          "name": "Unity Editor Log",
          "type": "webview"
        }
      ]
    },
    "debuggers": [
      {
        "type": "unity-for-cursor-attach",
        "label": "Unity for Cursor",
        "languages": [
          "csharp"
        ],
        "configurationAttributes": {
          "attach": {
            "properties": {}
          }
        },
        "initialConfigurations": [
          {
            "name": "Unity for Cursor: Attach to Unity Editor",
            "type": "unity-for-cursor-attach",
            "request": "attach"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Unity for Cursor: Attach to Unity Editor",
            "description": "自动发现本机运行的 Unity Editor 进程，并通过 ReSharper 的 mono 调试器 attach 上去",
            "body": {
              "name": "Unity for Cursor: Attach to Unity Editor",
              "type": "unity-for-cursor-attach",
              "request": "attach"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "chokidar": "^4.0.3"
  }
}
